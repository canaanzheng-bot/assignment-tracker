        <div class="heatmap-grid">
          ${dd.map(d => d.future
            ? `<div class="heatmap-cell hm-0" style="opacity:.4"><span class="hm-day">${d.day}</span><span class="hm-count">Future</span></div>`
            : `<div class="heatmap-cell hm-${d.total}"><span class="hm-day">${d.day}</span><span class="hm-count">${d.total}/4</span></div>`
          ).join('')}
        </div>
        <div class="heatmap-legend"><span>Less</span><div class="heatmap-legend-swatch" style="background:#F5F5F0;border:1px solid var(--border)"></div><div class="heatmap-legend-swatch" style="background:#FFF3CD"></div><div class="heatmap-legend-swatch" style="background:#FFEAA7"></div><div class="heatmap-legend-swatch" style="background:#D5F5E3"></div><div class="heatmap-legend-swatch" style="background:#82E0AA"></div><span>More</span></div>
      </div>
      <!-- Reports -->
      <div class="detail-card detail-card-full">
        <div class="detail-card-title">📄 Generate Reports</div>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <button class="btn btn-solid" onclick="genPDF('${sid}','weekly')">📄 Weekly Report</button>
          <button class="btn btn-outline" onclick="genPDF('${sid}','monthly')">📄 Monthly Report</button>
          <button class="btn btn-outline" onclick="genPDF('${sid}','unit')">📄 Unit Report</button>
        </div>
      </div>
    </div>`;
}

function showMainPage() {
  document.getElementById('mainPage').style.display = 'block';
  document.getElementById('studentPage').style.display = 'none';
  document.getElementById('backBtn').style.display = 'none';
  document.getElementById('headerSubtitle').textContent = 'Assignment Tracker';
  renderAll();
}

// ═══════════════════════════════════════════
// PDF REPORT GENERATION
// ═══════════════════════════════════════════
function genPDF(sid, type) {
  const s = students.find(x => x.id === sid);
  if (!s) return;
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF();
  const pw = doc.internal.pageSize.width;

  // Header
  doc.setFillColor(45, 90, 61);
  doc.rect(0, 0, pw, 32, 'F');
  doc.setTextColor(255, 255, 255);
  doc.setFontSize(18);
  doc.text('MSLC Assignment Tracker', 14, 16);
  doc.setFontSize(10);
  doc.text('Generated: ' + new Date().toLocaleDateString(), 14, 24);
  doc.setTextColor(44, 44, 44);
  doc.setFontSize(16);
  doc.text(s.name + (s.emoji ? ' ' + s.emoji : ''), 14, 46);
  let y = 54;

  const today = new Date(); today.setHours(0,0,0,0);

  if (type === 'weekly') {
    const wl = calendar[currentWeekIndex] ? calendar[currentWeekIndex].label : 'Current Week';
    doc.setFontSize(12); doc.setTextColor(107, 107, 107);
    doc.text(wl + ' - Weekly Report', 14, y); y += 12;
    const ds = getWeekDates(currentWeekIndex);
    const td = []; let wd = 0;
    ds.forEach((d, i) => {
      if (d > today) return;
      const k = sid + '-' + fmtDate(d), ci = checkIns[k] || {};
      const cnt = CATEGORIES.filter(c => ci[c]).length;
      const p = cnt >= DAY_PASS; if (p) wd++;
      td.push([DAYS[i] + ' ' + fmtShort(d), ci.Math?'Yes':'—', ci.Chinese?'Yes':'—', ci.Journal?'Yes':'—', ci.Homework?'Yes':'—', cnt + '/4 ' + (p ? 'PASS' : '')]);
    });
    doc.autoTable({ startY: y, head: [['Day','Math','Chinese','Journal','Homework','Status']], body: td, theme: 'grid', styles: { fontSize: 10, cellPadding: 4 }, headStyles: { fillColor: [45, 90, 61] } });
    y = doc.lastAutoTable.finalY + 12;
    const wp2 = wd >= WEEK_PASS;
    doc.setFontSize(13); doc.setTextColor(wp2?39:192, wp2?174:57, wp2?96:43);
    doc.text('Week Result: ' + wd + '/5 days — ' + (wp2 ? 'PASSED' : 'NOT YET PASSED'), 14, y);

  } else if (type === 'monthly') {
    doc.setFontSize(12); doc.setTextColor(107, 107, 107);
    doc.text('Monthly Report (Last 4 Weeks)', 14, y); y += 12;
    const si2 = Math.max(0, currentWeekIndex - 3);
    const td = [];
    for (let wi = si2; wi <= currentWeekIndex; wi++) {
      const w = calendar[wi], ds = getWeekDates(wi);
      let wd = 0, cc = {}, dt = 0;
      CATEGORIES.forEach(c => cc[c] = 0);
      ds.forEach(d => { if (d > today) return; dt++; const k = sid + '-' + fmtDate(d), ci = checkIns[k] || {}; let cn = 0; CATEGORIES.forEach(c => { if (ci[c]) { cc[c]++; cn++; } }); if (cn >= DAY_PASS) wd++; });
      td.push([w ? w.label : 'Week ' + (wi + 1), cc.Math + '/' + dt, cc.Chinese + '/' + dt, cc.Journal + '/' + dt, cc.Homework + '/' + dt, wd + '/5 ' + (wd >= WEEK_PASS ? 'PASS' : '')]);
    }
    doc.autoTable({ startY: y, head: [['Week','Math','Chinese','Journal','Homework','Status']], body: td, theme: 'grid', styles: { fontSize: 10, cellPadding: 4 }, headStyles: { fillColor: [45, 90, 61] } });

  } else if (type === 'unit') {
    const cl = calendar[currentWeekIndex] ? calendar[currentWeekIndex].label : '';
    const um = cl.match(/Unit\s*(\d+)/i), un = um ? um[1] : '?';
    doc.setFontSize(12); doc.setTextColor(107, 107, 107);
    doc.text('Unit ' + un + ' Report', 14, y); y += 12;
    const uw = calendar.map((w, i) => ({ ...w, idx: i })).filter(w => { const m = (w.label || '').match(/Unit\s*(\d+)/i); return m && m[1] === un; });
    const td = []; let uwp = 0;
    uw.forEach(u => {
      const ds = getWeekDates(u.idx);
      let wd = 0;
      ds.forEach(d => { if (d > today) return; const k = sid + '-' + fmtDate(d), ci = checkIns[k] || {}; if (CATEGORIES.filter(c => ci[c]).length >= DAY_PASS) wd++; });
      const p = wd >= WEEK_PASS; if (p) uwp++;
      td.push([u.label || 'Week', wd + '/5', p ? 'PASS' : 'NOT PASS']);
    });
    doc.autoTable({ startY: y, head: [['Week','Days Passed','Status']], body: td, theme: 'grid', styles: { fontSize: 10, cellPadding: 4 }, headStyles: { fillColor: [45, 90, 61] } });
    y = doc.lastAutoTable.finalY + 12;
    doc.setFontSize(12); doc.setTextColor(44, 44, 44);
    doc.text('Unit Summary: ' + uwp + '/' + uw.length + ' weeks passed', 14, y);
  }

  const ph = doc.internal.pageSize.height;
  doc.setFontSize(8); doc.setTextColor(150, 150, 150);
  doc.text('MSLC Assignment Tracker', 14, ph - 10);
  doc.save(s.name + '_' + type + '_report.pdf');
  showToast(type.charAt(0).toUpperCase() + type.slice(1) + ' report downloaded!');
}

// ═══════════════════════════════════════════
// CALENDAR MODAL
// ═══════════════════════════════════════════
function openCalendarModal() {
  document.getElementById('calendarModal').classList.add('active');
  renderCalTable();
}
function closeCalendarModal() {
  document.getElementById('calendarModal').classList.remove('active');
}

function renderCalTable() {
  if (!calendar.length) {
    document.getElementById('calendarBody').innerHTML = '<p style="color:var(--text-muted)">No calendar data loaded.</p>';
    return;
  }
  let h = '<table class="cal-table"><thead><tr><th>#</th><th>Week</th><th>Monday</th><th>Status</th></tr></thead><tbody>';
  calendar.forEach((w, i) => {
    const ic = i === currentWeekIndex;
    const m = parseDate(w.mondayDate);
    const ds = m ? m.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : (w.mondayDate || '—');
    h += `<tr class="${ic ? 'active-week' : ''}"><td>${i+1}</td><td>${esc(w.label)}</td><td>${ds}</td><td>${w.active !== false ? '🟢 Active' : '⚪ Inactive'}${ic ? ' <span class="cal-active-badge">Current</span>' : ''}</td></tr>`;
  });
  h += '</tbody></table>';
  document.getElementById('calendarBody').innerHTML = h;
  setTimeout(() => {
    const r = document.querySelector('.cal-table .active-week');
    if (r) r.scrollIntoView({ block: 'center', behavior: 'smooth' });
  }, 100);
}

// ═══════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════
function showToast(m) {
  const t = document.getElementById('toast');
  t.textContent = m; t.classList.add('show');
  clearTimeout(window._tt);
  window._tt = setTimeout(() => t.classList.remove('show'), 3000);
}

async function refreshData() {
  showToast('Refreshing...');
  await loadAllData();
  showToast('Data refreshed!');
}

// Event listeners
document.getElementById('calendarModal').addEventListener('click', e => { if (e.target === e.currentTarget) closeCalendarModal(); });
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeCalendarModal();
  if (document.getElementById('mainPage').style.display !== 'none') {
    if (e.key === 'ArrowLeft') changeWeek(-1);
    if (e.key === 'ArrowRight') changeWeek(1);
  }
});

