        <div class="hero-stat"><div class="hero-stat-value">${pct}%</div><div class="hero-stat-label">Completion</div></div>
        <div class="hero-stat"><div class="hero-stat-value" style="color:${wp?'var(--success)':'var(--danger)'}">${wp?'✅':'⏳'}</div><div class="hero-stat-label">Week Status</div></div>
      </div>
    </div>
    <div class="detail-grid">
      <!-- Completion Rings -->
      <div class="detail-card">
        <div class="detail-card-title">📊 Weekly Completion</div>
        <div class="ring-container">
          <div class="ring-wrap"><svg viewBox="0 0 128 128"><circle class="ring-bg" cx="64" cy="64" r="54"/><circle class="ring-fill" cx="64" cy="64" r="54" stroke="${rc}" stroke-dasharray="${C}" stroke-dashoffset="${ro}"/></svg><div class="ring-text"><span class="ring-pct">${pct}%</span><span class="ring-label">Tasks Done</span></div></div>
          <div class="ring-wrap"><svg viewBox="0 0 128 128"><circle class="ring-bg" cx="64" cy="64" r="54"/><circle class="ring-fill" cx="64" cy="64" r="54" stroke="${drc}" stroke-dasharray="${C}" stroke-dashoffset="${dro}"/></svg><div class="ring-text"><span class="ring-pct">${wd}/${tp}</span><span class="ring-label">Days Passed</span></div></div>
        </div>
        <div style="text-align:center;margin-top:12px;font-size:13px;color:var(--text-secondary)">
          ${wp ? '<span style="color:var(--success);font-weight:600">✅ Week PASSED</span> — Met the 4/5 days requirement'
