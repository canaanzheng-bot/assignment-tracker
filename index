  const col = AVATAR_COLORS[si % AVATAR_COLORS.length];
  const ds = getWeekDates(currentWeekIndex);
  const today = new Date(); today.setHours(0,0,0,0);
  const wl = calendar[currentWeekIndex] ? calendar[currentWeekIndex].label : 'This Week';

  let wd = 0, catT = {};
  CATEGORIES.forEach(c => catT[c] = 0);
  let dd = [], tp = 0;

  ds.forEach((d, i) => {
    if (d > today) { dd.push({ day: DAYS[i], total: 0, future: true, counts: {} }); return; }
