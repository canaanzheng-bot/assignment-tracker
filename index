// RENDER MAIN PAGE
// ═══════════════════════════════════════════
function renderAll() { renderWeekLabel(); renderTableHeader(); renderTableBody(); renderStats(); }

function renderWeekLabel() {
  const w = calendar[currentWeekIndex];
  const l = w ? w.label : 'Week ' + (currentWeekIndex + 1);
  const ds = getWeekDates(currentWeekIndex);
  const dr = ds.length >= 5 ? fmtShort(ds[0]) + ' – ' + fmtShort(ds[4]) : '';
  document.getElementById('weekLabel').innerHTML = l + '<br><span class="week-date">' + dr + '</span>';
}

function renderTableHeader() {
  const ds = getWeekDates(currentWeekIndex);
  const today = new Date(); today.setHours(0,0,0,0);
  let h = '<tr><th style="min-width:160px">Student</th>';
  ds.forEach((d, i) => {
    const isT = d.getTime() === today.getTime();
    h += `<th class="day-col-group" colspan="4" style="${isT?'color:var(--primary);':''}">
      <div class="day-header">${DAYS[i]}${isT?' ✦':''}</div>
      <div class="day-date-label">${fmtShort(d)}</div></th>`;
  });
  h += '<th style="min-width:80px">Week</th></tr>';
  h += '<tr><th></th>';
  for (let i = 0; i < 5; i++) {
    CATEGORIES.forEach((c, ci) => {
      const a = c === 'Homework' ? 'HW' : c.substring(0, 2);
      h += `<th class="${ci===0?'day-col-group':''}" style="padding:4px 2px;">
        <span class="cat-label cat-${c.toLowerCase()}">${a}</span></th>`;
    });
  }
  h += '<th></th></tr>';
  document.getElementById('tableHead').innerHTML = h;
}

function renderTableBody() {
  const ds = getWeekDates(currentWeekIndex);
  const today = new Date(); today.setHours(0,0,0,0);
  let h = '';

  if (students.length === 0) {
    h = `<tr><td colspan="22" style="text-align:center;padding:40px;color:var(--text-muted);">
      No students loaded. Check API connection (click 🔧 Debug below).
    </td></tr>`;
  }

  students.forEach((s, si) => {
    const col = AVATAR_COLORS[si % AVATAR_COLORS.length];
    const init = (s.name || '?')[0].toUpperCase();
    let wd = 0;

    h += '<tr><td><div class="student-name-cell">' +
      `<div class="student-avatar" style="background:${col}">${init}</div>` +
      `<a class="student-name-link" onclick="showStudentPage('${s.id}')">${esc(s.name)}</a>` +
      `<span class="student-emoji">${s.emoji || ''}</span>` +
      '</div></td>';

    ds.forEach((d, di) => {
      const dk = fmtDate(d);
      const key = s.id + '-' + dk;
      const ci = checkIns[key] || {};
      let dc = 0;

      CATEGORIES.forEach((cat, catI) => {
        const chk = !!ci[cat];
        if (chk) dc++;
        const isFuture = d > today;
        h += `<td class="${catI===0?'day-col-group':''}" style="padding:4px 2px;">
          <button class="check-btn${chk?' checked':''}"${isFuture?' disabled':''} 
            onclick="toggleCheck('${s.id}','${dk}','${cat}',this)" title="${cat}">
            ${chk ? '✓' : ''}</button></td>`;
      });
      if (dc >= DAY_PASS) wd++;
    });

    let wc = 'week-fail';
    if (wd >= WEEK_PASS) wc = 'week-pass';
    else if (wd >= 2) wc = 'week-partial';
    h += `<td class="week-total-cell"><span class="${wc}">${wd}/5</span></td></tr>`;
  });

  document.getElementById('tableBody').innerHTML = h;
}

function renderStats() {
  const ds = getWeekDates(currentWeekIndex);
  const today = new Date(); today.setHours(0,0,0,0);
  const todayStr = fmtDate(today);
  document.getElementById('statStudents').textContent = students.length;

  let totDay = 0, totPoss = 0, todayComp = 0, weekPassCnt = 0;
  students.forEach(s => {
    let wd = 0;
    ds.forEach(d => {
      if (d > today) return;
      totPoss++;
      const k = s.id + '-' + fmtDate(d);
      const ci = checkIns[k] || {};
      if (CATEGORIES.filter(c => ci[c]).length >= DAY_PASS) { totDay++; wd++; }
    });
    const tk = s.id + '-' + todayStr;
    const tci = checkIns[tk] || {};
    if (CATEGORIES.filter(c => tci[c]).length >= DAY_PASS) todayComp++;
    if (wd >= WEEK_PASS) weekPassCnt++;
  });

  const wp = totPoss > 0 ? Math.round(totDay / totPoss * 100) : 0;
  document.getElementById('statWeekComp').textContent = wp + '%';
  document.getElementById('statWeekSub').textContent = totDay + ' of ' + totPoss + ' student-days';
  document.getElementById('statToday').textContent = todayComp;
  document.getElementById('statTodaySub').textContent = 'of ' + students.length + ' students';
  const pr = students.length > 0 ? Math.round(weekPassCnt / students.length * 100) : 0;
  document.getElementById('statPassRate').textContent = pr + '%';
  document.getElementById('statPassSub').textContent = weekPassCnt + ' of ' + students.length + ' passed';
}

// ═══════════════════════════════════════════
// TOGGLE CHECK-IN
// ═══════════════════════════════════════════
async function toggleCheck(sid, date, cat, btn) {
  const key = sid + '-' + date;
  if (!checkIns[key]) checkIns[key] = {};
  const nv = !checkIns[key][cat];
  checkIns[key][cat] = nv;

  if (nv) { btn.classList.add('checked'); btn.textContent = '✓'; }
  else { btn.classList.remove('checked'); btn.textContent = ''; }

  clearTimeout(window._st);
  window._st = setTimeout(() => { renderStats(); updateWeekTotals(); }, 100);

  try {
    await apiPost({ action: 'saveCheckIn', studentId: sid, date, category: cat, done: nv });
  } catch (e) {
    dbg('Save failed: ' + e.message, 'err');
    showToast('Save failed – check connection');
  }
}

function updateWeekTotals() {
  const ds = getWeekDates(currentWeekIndex);
  const today = new Date(); today.setHours(0,0,0,0);
  document.querySelectorAll('#tableBody tr').forEach((row, i) => {
    if (!students[i]) return;
    const s = students[i];
    let wd = 0;
    ds.forEach(d => {
      if (d > today) return;
      const k = s.id + '-' + fmtDate(d);
      const ci = checkIns[k] || {};
      if (CATEGORIES.filter(c => ci[c]).length >= DAY_PASS) wd++;
    });
    const td = row.querySelector('td:last-child');
    if (td) {
      let c = 'week-fail';
      if (wd >= WEEK_PASS) c = 'week-pass';
      else if (wd >= 2) c = 'week-partial';
      td.innerHTML = `<span class="${c}">${wd}/5</span>`;
    }
  });
}

