// DATA LOADING
// ═══════════════════════════════════════════
async function loadAllData() {
  const loadEl = document.getElementById('loadingState');
  loadEl.style.display = 'block';
  dbg('=== STARTING DATA LOAD ===', 'info');

  try {
    // Load all three endpoints
    const [sData, ciData, calData] = await Promise.all([
      apiFetch('getStudents'),
      apiFetch('getCheckIns'),
      apiFetch('getCalendar')
    ]);

    // ── Parse Students ──
    students = [];
    if (Array.isArray(sData)) {
      sData.forEach(s => {
        // Normalize: could have id/studentId/Id, name/studentName/Name, emoji
        const id = s.id || s.studentId || s.Id || s.ID || '';
        const name = s.name || s.studentName || s.Name || s.student || '';
        const emoji = s.emoji || s.Emoji || s.icon || '';
        if (id && name) students.push({ id: String(id), name, emoji });
      });
    }
    dbg(`Students parsed: ${students.length} → [${students.map(s=>s.name).join(', ')}]`, students.length > 0 ? 'ok' : 'warn');

    // ── Parse Calendar ──
    calendar = [];
    if (Array.isArray(calData)) {
      calData.forEach(w => {
        const label = w.label || w.Label || w.week || w.Week || w.weekLabel || '';
        const mondayDate = w.mondayDate || w.MondayDate || w.monday || w.Monday || w.date || w.startDate || '';
        const active = w.active !== false && w.active !== 'FALSE' && w.Active !== false;
        calendar.push({ label, mondayDate, active });
      });
    }
    dbg(`Calendar parsed: ${calendar.length} weeks`, calendar.length > 0 ? 'ok' : 'warn');
    if (calendar.length > 0) {
      dbg(`  First: "${calendar[0].label}" → ${calendar[0].mondayDate}`, 'info');
      dbg(`  Last: "${calendar[calendar.length-1].label}" → ${calendar[calendar.length-1].mondayDate}`, 'info');
    }

    // ── Parse Check-ins ──
    checkIns = {};
    if (Array.isArray(ciData)) {
      ciData.forEach(ci => {
        const sid = String(ci.studentId || ci.StudentId || ci.student_id || ci.id || '');
        const date = ci.date || ci.Date || ci.checkDate || '';
        if (!sid || !date) return;
        const key = sid + '-' + date;
        if (!checkIns[key]) checkIns[key] = {};

        // Method 1: Flat format { Math: true, Chinese: false, ... }
        CATEGORIES.forEach(cat => {
          const val = ci[cat] || ci[cat.toLowerCase()] || ci[cat.toUpperCase()];
          if (val === true || val === 'TRUE' || val === 1 || val === '1' || val === 'Yes' || val === 'yes' || val === 'Y') {
            checkIns[key][cat] = true;
          }
        });

        // Method 2: Category/done format { category: 'Math', done: true }
        if (ci.category) {
          const cat = CATEGORIES.find(c => c.toLowerCase() === (ci.category || '').toLowerCase());
          if (cat && (ci.done === true || ci.done === 'TRUE' || ci.done === 1)) {
            checkIns[key][cat] = true;
          }
        }

        // Method 3: categories as comma-separated string
        if (ci.categories && typeof ci.categories === 'string') {
          ci.categories.split(',').forEach(c => {
            const cat = CATEGORIES.find(x => x.toLowerCase() === c.trim().toLowerCase());
            if (cat) checkIns[key][cat] = true;
          });
        }
      });
    }
    const ciCount = Object.keys(checkIns).length;
    dbg(`Check-ins parsed: ${ciCount} student-day records`, ciCount > 0 ? 'ok' : 'warn');

    // Auto-select current week
    autoSelectWeek();
    dbg(`Current week: ${currentWeekIndex} → "${calendar[currentWeekIndex]?.label || 'N/A'}"`, 'ok');

    // Render
    renderAll();
    dbg('=== RENDER COMPLETE ===', 'ok');
  } catch (err) {
    dbg(`FATAL LOAD ERROR: ${err.message}`, 'err');
    showToast('Failed to load data. Check debug console.');
  } finally {
    loadEl.style.display = 'none';
  }
}

// ═══════════════════════════════════════════
// DATE HELPERS
// ═══════════════════════════════════════════
function parseDate(str) {
  if (!str) return null;
  if (str instanceof Date) return new Date(str.getFullYear(), str.getMonth(), str.getDate());
  // Handle "YYYY-MM-DD"
  let m = String(str).match(/^(\d{4})-(\d{1,2})-(\d{1,2})/);
  if (m) return new Date(+m[1], +m[2]-1, +m[3]);
  // Handle "MM/DD/YYYY"
  m = String(str).match(/^(\d{1,2})\/(\d{1,2})\/(\d{4})/);
  if (m) return new Date(+m[3], +m[1]-1, +m[2]);
  // Handle "Month DD, YYYY"
  let d = new Date(str);
  if (!isNaN(d)) return new Date(d.getFullYear(), d.getMonth(), d.getDate());
  // Handle epoch
  if (typeof str === 'number') {
    d = new Date(str);
    if (!isNaN(d)) return new Date(d.getFullYear(), d.getMonth(), d.getDate());
  }
  dbg(`⚠ Could not parse date: "${str}"`, 'warn');
  return null;
}

function autoSelectWeek() {
  const today = new Date(); today.setHours(0,0,0,0);
  let best = 0, bestDiff = Infinity;
  calendar.forEach((w, i) => {
    const mon = parseDate(w.mondayDate); if (!mon) return;
    const fri = new Date(mon); fri.setDate(fri.getDate() + 4);
    if (today >= mon && today <= fri) { best = i; bestDiff = 0; }
    else { const diff = Math.abs(today - mon); if (diff < bestDiff) { bestDiff = diff; best = i; } }
  });
  currentWeekIndex = best;
}

function getWeekDates(wi) {
  const w = calendar[wi]; if (!w) return [];
  const mon = parseDate(w.mondayDate); if (!mon) return [];
  return Array.from({length:5}, (_,i) => { const d = new Date(mon); d.setDate(d.getDate()+i); return d; });
}

function fmtDate(d) { return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0'); }
function fmtShort(d) { return (d.getMonth()+1)+'/'+d.getDate(); }
function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

