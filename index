<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MSLC Assignment Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<style>
:root {
  --bg: #F8F6F1;
  --card: #FFFFFF;
  --primary: #2D5A3D;
  --primary-light: #E8F0EB;
  --primary-hover: #3D7A52;
  --accent: #D4845A;
  --text: #2C2C2C;
  --text-secondary: #6B6B6B;
  --text-muted: #9A9A9A;
  --border: #E8E4DE;
  --border-light: #F0EDE8;
  --danger: #C0392B;
  --danger-light: #FDECEA;
  --success: #27AE60;
  --success-light: #E8F8F0;
  --warning: #F39C12;
  --warning-light: #FFF8E8;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.06);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.06), 0 2px 4px rgba(0,0,0,0.04);
  --shadow-lg: 0 12px 32px rgba(0,0,0,0.08), 0 4px 8px rgba(0,0,0,0.04);
  --radius: 10px;
  --radius-lg: 16px;
  --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);line-height:1.5;min-height:100vh}

/* Header */
.header{background:var(--primary);color:#fff;padding:0 32px;height:64px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(0,0,0,.15)}
.header-left{display:flex;align-items:center;gap:14px}
.header-logo{font-family:'Fraunces',serif;font-size:22px;font-weight:700;letter-spacing:-.5px}
.header-divider{width:1px;height:28px;background:rgba(255,255,255,.25)}
.header-subtitle{font-size:13px;opacity:.8}
.header-actions{display:flex;align-items:center;gap:10px}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:500;font-family:inherit;cursor:pointer;border:none;transition:var(--transition);white-space:nowrap}
.btn-ghost{background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.15)}
.btn-ghost:hover{background:rgba(255,255,255,.22)}
.btn-solid{background:var(--primary);color:#fff}
.btn-solid:hover{background:var(--primary-hover)}
.btn-outline{background:transparent;color:var(--primary);border:1.5px solid var(--border)}
.btn-outline:hover{background:var(--primary-light);border-color:var(--primary)}
.btn-sm{padding:5px 10px;font-size:12px}
.btn-danger{background:var(--danger);color:#fff}

.back-btn{display:none;align-items:center;gap:6px;background:none;border:none;color:#fff;font-family:inherit;font-size:14px;cursor:pointer;padding:6px 0;opacity:.9}
.back-btn:hover{opacity:1}
.back-btn svg{width:18px;height:18px}

.main{max-width:1200px;margin:0 auto;padding:28px 32px 60px}

/* Week bar */
.week-bar{display:flex;align-items:center;gap:12px;margin-bottom:24px;flex-wrap:wrap}
.week-nav{display:flex;align-items:center;gap:2px;background:var(--card);border-radius:var(--radius);border:1px solid var(--border);box-shadow:var(--shadow-sm);overflow:hidden}
.week-nav-btn{background:none;border:none;padding:10px 12px;cursor:pointer;color:var(--text-secondary);transition:var(--transition);display:flex;align-items:center}
.week-nav-btn:hover{background:var(--primary-light);color:var(--primary)}
.week-nav-btn svg{width:16px;height:16px}
.week-label{font-weight:600;font-size:15px;padding:0 8px;min-width:200px;text-align:center}
.week-date{font-size:13px;color:var(--text-muted);font-weight:400}
.week-bar-right{margin-left:auto;display:flex;gap:8px}

/* Stats */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:24px}
.stat-card{background:var(--card);border-radius:var(--radius);padding:18px 20px;border:1px solid var(--border);box-shadow:var(--shadow-sm)}
.stat-label{font-size:12px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.6px;font-weight:500;margin-bottom:6px}
.stat-value{font-family:'Fraunces',serif;font-size:28px;font-weight:700}
.stat-sub{font-size:12px;color:var(--text-secondary);margin-top:2px}

/* Table */
.table-card{background:var(--card);border-radius:var(--radius-lg);border:1px solid var(--border);box-shadow:var(--shadow-md);overflow:hidden}
.table-header{padding:18px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.table-title{font-family:'Fraunces',serif;font-size:18px;font-weight:600}
.table-scroll{overflow-x:auto}
table{width:100%;border-collapse:collapse;min-width:700px}
thead th{padding:12px 10px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.7px;color:var(--text-muted);background:#FAFAF7;border-bottom:1px solid var(--border);text-align:center;white-space:nowrap}
thead th:first-child{text-align:left;padding-left:24px}
.day-col-group{border-left:2px solid var(--border)}
.day-header{font-size:12px;font-weight:600;color:var(--text);text-transform:none;letter-spacing:0}
.day-date-label{font-size:10px;color:var(--text-muted);font-weight:400}
tbody tr{border-bottom:1px solid var(--border-light);transition:var(--transition)}
tbody tr:hover{background:#FCFBF8}
tbody tr:last-child{border-bottom:none}
td{padding:6px 10px;text-align:center;vertical-align:middle}
td:first-child{text-align:left;padding-left:24px}
.student-name-cell{display:flex;align-items:center;gap:10px}
.student-avatar{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:#fff;flex-shrink:0}
.student-name-link{font-weight:500;font-size:14px;color:var(--primary);cursor:pointer;text-decoration:none;transition:var(--transition)}
.student-name-link:hover{color:var(--primary-hover);text-decoration:underline}
.student-emoji{font-size:13px;margin-left:2px}

/* Check buttons */
.check-btn{width:34px;height:34px;border-radius:8px;border:2px solid var(--border);background:var(--card);cursor:pointer;display:inline-flex;align-items:center;justify-content:center;transition:var(--transition);font-size:16px;line-height:1}
.check-btn:hover{border-color:var(--primary);background:var(--primary-light);transform:scale(1.08)}
.check-btn.checked{background:var(--success);border-color:var(--success);color:#fff}
.check-btn.checked:hover{background:#219a52;border-color:#219a52}
.check-btn:disabled{opacity:.3;cursor:default;transform:none}

.cat-label{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.4px;display:block;margin-bottom:2px}
.cat-math{color:#8E44AD}.cat-chinese{color:#C0392B}.cat-journal{color:#2980B9}.cat-homework{color:#D4845A}

.week-total-cell{font-family:'Fraunces',serif;font-weight:700;font-size:16px}
.week-pass{color:var(--success);background:var(--success-light);border-radius:20px;padding:4px 12px;display:inline-block}
.week-fail{color:var(--danger);background:var(--danger-light);border-radius:20px;padding:4px 12px;display:inline-block}
.week-partial{color:var(--warning);background:var(--warning-light);border-radius:20px;padding:4px 12px;display:inline-block}

/* Student page */
#studentPage{display:none}
.student-hero{background:var(--card);border-radius:var(--radius-lg);border:1px solid var(--border);box-shadow:var(--shadow-md);padding:28px 32px;margin-bottom:24px;display:flex;align-items:center;gap:24px}
.hero-avatar{width:68px;height:68px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:700;color:#fff;flex-shrink:0}
.hero-info{flex:1}
.hero-name{font-family:'Fraunces',serif;font-size:26px;font-weight:700;margin-bottom:4px}
.hero-meta{font-size:13px;color:var(--text-secondary)}
.hero-stats{display:flex;gap:24px}
.hero-stat{text-align:center}
.hero-stat-value{font-family:'Fraunces',serif;font-size:24px;font-weight:700}
.hero-stat-label{font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:.5px}

.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:24px}
.detail-card{background:var(--card);border-radius:var(--radius-lg);border:1px solid var(--border);box-shadow:var(--shadow-sm);padding:24px}
.detail-card-full{grid-column:1/-1}
.detail-card-title{font-family:'Fraunces',serif;font-size:16px;font-weight:600;margin-bottom:16px;display:flex;align-items:center;gap:8px}

/* Rings */
.ring-container{display:flex;align-items:center;gap:32px;justify-content:center;padding:10px 0}
.ring-wrap{position:relative;width:140px;height:140px}
.ring-wrap svg{transform:rotate(-90deg);width:140px;height:140px}
.ring-bg{fill:none;stroke:var(--border);stroke-width:10}
.ring-fill{fill:none;stroke-width:10;stroke-linecap:round;transition:stroke-dashoffset .8s cubic-bezier(.4,0,.2,1)}
.ring-text{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center}
.ring-pct{font-family:'Fraunces',serif;font-size:30px;font-weight:700;display:block}
.ring-label{font-size:11px;color:var(--text-muted)}

/* Bars */
.bar-chart{display:flex;align-items:flex-end;gap:8px;height:160px;padding-top:10px}
.bar-group{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;height:100%;justify-content:flex-end}
.bar-stack{width:100%;max-width:48px;display:flex;flex-direction:column;gap:2px}
.bar-segment{border-radius:4px;min-height:3px;transition:all .4s ease}
.bar-day-label{font-size:11px;font-weight:500;color:var(--text-secondary)}
.bar-count{font-size:11px;font-weight:600;color:var(--text)}

/* Category */
.cat-breakdown{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.cat-stat{background:#FAFAF7;border-radius:var(--radius);padding:14px 16px;border:1px solid var(--border-light)}
.cat-stat-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px}
.cat-stat-name{font-size:13px;font-weight:600}
.cat-stat-pct{font-family:'Fraunces',serif;font-size:18px;font-weight:700}
.cat-stat-bar{height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.cat-stat-bar-fill{height:100%;border-radius:3px;transition:width .6s ease}

/* Heatmap */
.heatmap-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-top:8px}
.heatmap-cell{aspect-ratio:1;border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:10px;font-weight:500;border:1px solid transparent;transition:var(--transition);cursor:default}
.heatmap-cell:hover{transform:scale(1.05)}
.hm-day{font-weight:600;font-size:11px}.hm-count{font-size:9px;opacity:.8}
.hm-0{background:#F5F5F0;color:var(--text-muted);border-color:var(--border-light)}
.hm-1{background:#FFF3CD;color:#856404}.hm-2{background:#FFEAA7;color:#7D6608}
.hm-3{background:#D5F5E3;color:#1E8449}.hm-4{background:#82E0AA;color:#1B6B38}
.heatmap-legend{display:flex;align-items:center;gap:6px;margin-top:12px;font-size:11px;color:var(--text-muted)}
.heatmap-legend-swatch{width:14px;height:14px;border-radius:3px}

/* Modal */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.modal-overlay.active{display:flex}
.modal{background:var(--card);border-radius:var(--radius-lg);box-shadow:var(--shadow-lg);max-width:640px;width:90%;max-height:80vh;overflow:hidden;display:flex;flex-direction:column}
.modal-header{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.modal-title{font-family:'Fraunces',serif;font-size:18px;font-weight:600}
.modal-close{background:none;border:none;cursor:pointer;color:var(--text-muted);padding:4px;border-radius:6px;transition:var(--transition)}
.modal-close:hover{background:#f0f0f0;color:var(--text)}
.modal-body{padding:24px;overflow-y:auto;flex:1}
.modal-footer{padding:16px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end;gap:10px}
.cal-table{width:100%;border-collapse:collapse;font-size:13px}
.cal-table th{padding:8px 10px;text-align:left;font-weight:600;background:#FAFAF7;border-bottom:1px solid var(--border);font-size:11px;text-transform:uppercase;letter-spacing:.5px;color:var(--text-muted)}
.cal-table td{padding:8px 10px;border-bottom:1px solid var(--border-light);text-align:left}
.cal-table tr.active-week td{background:var(--primary-light);font-weight:500}
.cal-active-badge{display:inline-block;background:var(--primary);color:#fff;font-size:10px;padding:2px 8px;border-radius:10px;font-weight:600}

/* Loading */
.loading-state{text-align:center;padding:60px 20px;color:var(--text-muted)}
.spinner{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--primary);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 16px}
@keyframes spin{to{transform:rotate(360deg)}}

/* Toast */
.toast{position:fixed;bottom:24px;right:24px;background:var(--text);color:#fff;padding:12px 20px;border-radius:var(--radius);font-size:13px;font-weight:500;box-shadow:var(--shadow-lg);z-index:300;opacity:0;transform:translateY(10px);transition:all .3s ease;pointer-events:none}
.toast.show{opacity:1;transform:translateY(0)}

/* Debug console */
#debugPanel{display:none;position:fixed;bottom:0;left:0;right:0;max-height:40vh;background:#1a1a2e;color:#0f0;font-family:'Courier New',monospace;font-size:12px;z-index:500;overflow-y:auto;border-top:3px solid #e94560;padding:12px 16px}
#debugPanel.open{display:block}
#debugPanel .dbg-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;color:#e94560;font-weight:bold;font-size:14px}
#debugPanel .dbg-line{margin:2px 0;padding:2px 0;border-bottom:1px solid rgba(255,255,255,.05)}
#debugPanel .dbg-ok{color:#0f0}
#debugPanel .dbg-err{color:#e94560}
#debugPanel .dbg-warn{color:#f39c12}
#debugPanel .dbg-info{color:#3498db}
.debug-toggle{position:fixed;bottom:8px;left:8px;z-index:501;background:#1a1a2e;color:#e94560;border:1px solid #e94560;padding:4px 10px;border-radius:6px;font-size:11px;font-family:monospace;cursor:pointer;opacity:.6}
.debug-toggle:hover{opacity:1}

/* Responsive */
@media(max-width:768px){
  .main{padding:16px}.stats-row{grid-template-columns:repeat(2,1fr);gap:10px}
  .detail-grid{grid-template-columns:1fr}.header{padding:0 16px}
  .student-hero{flex-direction:column;text-align:center;padding:20px}
  .hero-stats{justify-content:center}.ring-container{flex-direction:column}
  .cat-breakdown{grid-template-columns:1fr}
}
</style>
</head>
<body>

<header class="header">
  <div class="header-left">
    <button class="back-btn" id="backBtn" onclick="showMainPage()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      Back
    </button>
    <div class="header-logo">MSLC</div>
    <div class="header-divider"></div>
    <div class="header-subtitle" id="headerSubtitle">Assignment Tracker</div>
  </div>
  <div class="header-actions">
    <button class="btn btn-ghost" onclick="openCalendarModal()">📅 Calendar</button>
    <button class="btn btn-ghost" onclick="refreshData()">🔄 Refresh</button>
  </div>
</header>

<div id="mainPage" class="main">
  <div class="week-bar">
    <div class="week-nav">
      <button class="week-nav-btn" onclick="changeWeek(-1)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="week-label" id="weekLabel">Loading...</div>
      <button class="week-nav-btn" onclick="changeWeek(1)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
    <div class="week-bar-right">
      <button class="btn btn-outline btn-sm" onclick="goToCurrentWeek()">Today</button>
    </div>
  </div>

  <div class="stats-row">
    <div class="stat-card"><div class="stat-label">Students</div><div class="stat-value" id="statStudents">&mdash;</div></div>
    <div class="stat-card"><div class="stat-label">Week Completion</div><div class="stat-value" id="statWeekComp">&mdash;</div><div class="stat-sub" id="statWeekSub"></div></div>
    <div class="stat-card"><div class="stat-label">Today's Check-ins</div><div class="stat-value" id="statToday">&mdash;</div><div class="stat-sub" id="statTodaySub"></div></div>
    <div class="stat-card"><div class="stat-label">Weekly Pass Rate</div><div class="stat-value" id="statPassRate">&mdash;</div><div class="stat-sub" id="statPassSub"></div></div>
  </div>

  <div class="table-card">
    <div class="table-header">
      <div class="table-title">📋 Weekly Check-in</div>
    </div>
    <div class="table-scroll">
      <table><thead id="tableHead"></thead><tbody id="tableBody"></tbody></table>
    </div>
  </div>

  <div class="loading-state" id="loadingState">
    <div class="spinner"></div>
    <div>Loading assignment data...</div>
  </div>
</div>

<div id="studentPage" class="main"></div>

<!-- Calendar Modal -->
<div class="modal-overlay" id="calendarModal">
  <div class="modal">
    <div class="modal-header">
      <div class="modal-title">📅 School Calendar</div>
      <button class="modal-close" onclick="closeCalendarModal()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="modal-body" id="calendarBody"><div class="loading-state"><div class="spinner"></div>Loading calendar...</div></div>
    <div class="modal-footer">
      <div style="font-size:12px;color:var(--text-muted);flex:1">Calendar is managed in Google Sheets</div>
      <button class="btn btn-outline" onclick="closeCalendarModal()">Close</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<!-- Debug Panel -->
<button class="debug-toggle" onclick="toggleDebug()">🔧 Debug</button>
<div id="debugPanel">
  <div class="dbg-header">
    <span>API Debug Console</span>
    <button onclick="toggleDebug()" style="background:none;border:none;color:#e94560;cursor:pointer;font-size:16px">✕</button>
  </div>
  <div id="debugLog"></div>
</div>

<script>
// ═══════════════════════════════════════════
// CONFIG
// ═══════════════════════════════════════════
const API_BASE = 'https://script.google.com/macros/s/AKfycbzr2z1ERKXAzYfyF2Ex3MQNjTEs-g6AxhmhfTZyhrkiz3znfjyuitERlpOKyzvR-fas/exec';
const CATEGORIES = ['Math', 'Chinese', 'Journal', 'Homework'];
const CAT_COLORS = { Math: '#8E44AD', Chinese: '#C0392B', Journal: '#2980B9', Homework: '#D4845A' };
const CAT_ICONS = { Math: '🔢', Chinese: '🀄', Journal: '📓', Homework: '📚' };
const DAYS = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'];
const AVATAR_COLORS = ['#2D5A3D','#8E44AD','#2980B9','#C0392B','#D4845A','#1ABC9C','#E67E22','#3498DB','#E74C3C','#9B59B6','#16A085','#F39C12','#2ECC71','#E91E63','#00BCD4'];
const DAY_PASS = 3;  // 3 of 4 categories to pass a day
const WEEK_PASS = 4; // 4 of 5 days to pass a week

// ═══════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════
let students = [];
let checkIns = {};   // key: "studentId-YYYY-MM-DD" → { Math: true, Chinese: false, ... }
let calendar = [];
let currentWeekIndex = 0;

// ═══════════════════════════════════════════
// DEBUG LOGGER
// ═══════════════════════════════════════════
function dbg(msg, type = 'info') {
  const ts = new Date().toLocaleTimeString();
  const el = document.getElementById('debugLog');
  if (el) {
    const cls = type === 'ok' ? 'dbg-ok' : type === 'err' ? 'dbg-err' : type === 'warn' ? 'dbg-warn' : 'dbg-info';
    el.innerHTML += `<div class="dbg-line ${cls}">[${ts}] ${msg}</div>`;
    el.scrollTop = el.scrollHeight;
  }
  if (type === 'err') console.error(msg);
  else console.log(`[${type}]`, msg);
}

function toggleDebug() {
  document.getElementById('debugPanel').classList.toggle('open');
}

// ═══════════════════════════════════════════
// FLEXIBLE API FETCH
// Handles Google Apps Script quirks:
//   - redirects, CORS, wrapped responses
// ═══════════════════════════════════════════
async function apiFetch(action) {
  const url = API_BASE + '?action=' + encodeURIComponent(action);
  dbg(`Fetching: ${action} → ${url}`);

  try {
    const resp = await fetch(url, {
      method: 'GET',
      redirect: 'follow',
      headers: { 'Accept': 'application/json' }
    });

    dbg(`Response status: ${resp.status} ${resp.statusText} (redirected: ${resp.redirected}, url: ${resp.url})`, resp.ok ? 'ok' : 'err');

    const raw = await resp.text();
    dbg(`Raw response (first 500 chars): ${raw.substring(0, 500)}`, raw.length > 0 ? 'info' : 'warn');

    if (!raw || raw.trim().length === 0) {
      dbg(`⚠ Empty response for ${action}`, 'warn');
      return [];
    }

    let parsed;
    try {
      parsed = JSON.parse(raw);
    } catch (e) {
      dbg(`JSON parse failed: ${e.message}`, 'err');
      // Try removing BOM or wrapper
      const cleaned = raw.replace(/^\uFEFF/, '').trim();
      // Check if it's JSONP: callback({...})
      const jsonpMatch = cleaned.match(/^[a-zA-Z_]\w*\((.+)\);\s*$/s);
      if (jsonpMatch) {
        dbg('Detected JSONP, extracting...', 'warn');
        parsed = JSON.parse(jsonpMatch[1]);
      } else {
        // Try to find JSON in the response
        const jsonMatch = cleaned.match(/[\[{][\s\S]*[\]}]/);
        if (jsonMatch) {
          parsed = JSON.parse(jsonMatch[0]);
        } else {
          dbg(`Cannot parse response for ${action}`, 'err');
          return [];
        }
      }
    }

    dbg(`Parsed type: ${typeof parsed}, isArray: ${Array.isArray(parsed)}`, 'ok');

    // Handle various wrapper formats from Google Apps Script
    // Could be: raw array, { data: [...] }, { students: [...] }, { result: [...] }, etc.
    let result = null;

    if (Array.isArray(parsed)) {
      result = parsed;
    } else if (parsed && typeof parsed === 'object') {
      // Log all top-level keys
      const keys = Object.keys(parsed);
      dbg(`Response keys: [${keys.join(', ')}]`, 'info');

      // Try known wrapper keys
      if (parsed.data && Array.isArray(parsed.data)) result = parsed.data;
      else if (parsed.result && Array.isArray(parsed.result)) result = parsed.result;
      else if (parsed.students && action === 'getStudents') result = parsed.students;
      else if (parsed.checkins && action === 'getCheckIns') result = parsed.checkins;
      else if (parsed.checkIns && action === 'getCheckIns') result = parsed.checkIns;
      else if (parsed.calendar && action === 'getCalendar') result = parsed.calendar;
      else if (parsed.weeks && action === 'getCalendar') result = parsed.weeks;
      else if (parsed.rows) result = parsed.rows;
      else if (parsed.values) result = parsed.values;
      else {
        // If it has an array as first value, use that
        for (const key of keys) {
          if (Array.isArray(parsed[key])) {
            dbg(`Using key "${key}" as data array (length: ${parsed[key].length})`, 'warn');
            result = parsed[key];
            break;
          }
        }
        // If still no array found, maybe it's a single object response
        if (!result) {
          dbg(`No array found in response. Using parsed object as-is.`, 'warn');
          result = parsed;
        }
      }
    }

    if (Array.isArray(result)) {
      dbg(`✓ ${action}: got ${result.length} items`, 'ok');
      if (result.length > 0) {
        dbg(`  Sample item keys: [${Object.keys(result[0]).join(', ')}]`, 'info');
        dbg(`  Sample item: ${JSON.stringify(result[0]).substring(0, 300)}`, 'info');
      }
    } else {
      dbg(`✓ ${action}: got object with keys [${Object.keys(result || {}).join(', ')}]`, 'ok');
    }

    return result || [];
  } catch (err) {
    dbg(`✗ FETCH ERROR for ${action}: ${err.message}`, 'err');
    dbg(`  Stack: ${err.stack}`, 'err');
    return [];
  }
}

async function apiPost(data) {
  dbg(`POST: ${JSON.stringify(data).substring(0, 200)}`);
  try {
    const resp = await fetch(API_BASE, {
      method: 'POST',
      redirect: 'follow',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify(data)
    });
    const raw = await resp.text();
    dbg(`POST response: ${raw.substring(0, 200)}`, 'ok');
    try { return JSON.parse(raw); } catch(e) { return { ok: true, raw }; }
  } catch (err) {
    dbg(`POST error: ${err.message}`, 'err');
    throw err;
  }
}

